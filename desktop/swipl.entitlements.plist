<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Foreign extensions (e.g. ssl4pl.so, archive4pl.so) and
         packs the user installs later are not necessarily signed by
         the same Developer ID as the host binary. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- SWI-Prolog's VM emits dispatch code into dynamically-allocated
         memory; foreign extensions may JIT too. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
